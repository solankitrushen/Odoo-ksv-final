{
  "name": "rental-portal-backend",
  "version": "1.0.0",
  "description": "Rental Portal API",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "lint": "eslint .",
    "lint:ci": "eslint .",
    "seed:rental": "node scripts/seed-rental.mjs",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --testPathPattern=__tests__/rental",
    "test:rental": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --testPathPattern=__tests__/rental",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --runInBand --testPathPattern=__tests__/rental",
    "postinstall": "node -e \"console.log('Deps OK. Tests need local MongoDB on 127.0.0.1:27017 or set MONGODB_TEST_URI')\"",
    "audit": "npm audit"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.5.1",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.2",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "disposable-email-domains": "^1.0.62",
    "dotenv": "^16.3.1",
    "ecdsa-sig-formatter": "^1.0.11",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.11.2",
    "helmet": "^7.1.0",
    "imapflow": "^1.3.3",
    "js-cookie": "^3.0.5",
    "jsdom": "^22.1.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "mongoose": "^7.6.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.13.0",
    "razorpay": "^2.9.6",
    "xss": "^1.0.14",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^29.7.0",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
